# Ecom-OS production env (copy to .env, fill in, keep secret — .env is gitignored).
# Blessed deploy: all-in-one Docker on a fresh always-on VPS, single origin via the
# proxy, public HTTPS hostname via Cloudflare Tunnel (no inbound ports). See
# docs/ecom-os/deploy.md.

# --- core ---
AUTH_MODE=local
# REQUIRED, >= 50 chars. Generate: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
LOCAL_AUTH_TOKEN=
# Single-origin: the browser calls /api on whatever host serves the app.
NEXT_PUBLIC_API_URL=same-origin
# Public origin the backend advertises. Set to your tunnel hostname in production.
BASE_URL=https://app.example.com
# Same host (single origin) — keep in sync with BASE_URL.
CORS_ORIGINS=https://app.example.com
DB_AUTO_MIGRATE=true

# --- database (internal to the compose network) ---
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong

# --- connectors (resolved as Secrets; never logged) ---
COMPOSIO_API_KEY=
SHOPIFY_STORE_URL=your-store.myshopify.com
# Either connect Shopify via Composio, or mint a direct token with
# scripts/bootstrap/shopify_oauth.py:
SHOPIFY_ACCESS_TOKEN=
# Separate, scoped app for refunds only (write_orders). Leave empty to keep
# refunds disabled (Invariant 2).
SHOPIFY_REFUND_ACCESS_TOKEN=

# --- CS agent brain ---
# "" = deterministic WISMO (safe default) | "llm" = Anthropic | "hermes" = Hermes subagent
CS_RUNTIME=
ANTHROPIC_API_KEY=
HERMES_GATEWAY_URL=
HERMES_API_KEY=

# --- Cloudflare Tunnel (public HTTPS hostname, no open ports) ---
# Create a tunnel in the Cloudflare dashboard, route your hostname -> http://proxy:80,
# then paste the tunnel token here. Leave empty to run local-only on PROXY_PORT.
TUNNEL_TOKEN=
PROXY_PORT=8080
